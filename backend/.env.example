# Supabase PostgreSQL 연결 정보
# Supabase 대시보드 > Settings > Database > Connection string (URI) 에서 확인
SUPABASE_DB_URL=jdbc:postgresql://<supabase-host>:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# JWT Secret (최소 64자 이상의 랜덤 문자열)
# 생성 방법: openssl rand -base64 64
JWT_SECRET=your-very-long-secret-key-minimum-64-characters-long-please-change-this

# CORS 허용 오리진 (프론트엔드 URL)
APP_ALLOWED_ORIGINS=http://localhost:3000
